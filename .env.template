# EnergyBot Configuration Template
# Instructions: Copy this file to '.env' and fill in your keys.

# --- AI Connection (GDPR Compliance) ---
# Use Groq, Azure OpenAI, or a local provider like Ollama.
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your_key_here
LLM_MODEL_NAME=llama-3.3-70b-versatile

# --- App Security ---
APP_USERNAME=admin
APP_PASSWORD=choose_a_password_here

# --- Storage ---
EMBED_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
OFFLINE_MODE=false

# --- OSRM Configuration ---
# If running via Docker Compose, use http://osrm:5000, otherwise http://localhost:5000
OSRM_BASE_URL=http://localhost:5000
